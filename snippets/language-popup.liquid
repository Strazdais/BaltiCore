<div id="spars-lang-popup" style="display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.6);z-index:99999;align-items:center;justify-content:center;">
  <div style="background:#1a1a1a;border-radius:12px;padding:40px 32px;max-width:420px;width:90%;text-align:center;border:1px solid #333;">
    {% if shop.metafields.global.logo %}
      <img src="{{ 'spars-logo.png' | asset_url }}" alt="{{ shop.name }}" style="max-width:180px;margin-bottom:24px;" onerror="this.style.display='none';this.nextElementSibling.style.display='block';">
      <h1 style="display:none;color:#c8a951;font-size:28px;margin:0 0 24px;font-weight:700;">{{ shop.name }}</h1>
    {% else %}
      <h1 style="color:#c8a951;font-size:28px;margin:0 0 24px;font-weight:700;">{{ shop.name }}</h1>
    {% endif %}
    <p style="color:#fff;font-size:16px;margin:0 0 8px;">Choose your language</p>
    <p style="color:#ccc;font-size:14px;margin:0 0 32px;">Izvēlieties valodu</p>
    <div id="spars-lang-buttons" style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;">
      <button onclick="sparsSelectLang('en')" id="spars-btn-en" style="flex:1;min-width:140px;padding:14px 24px;font-size:16px;font-weight:600;border:2px solid #555;border-radius:8px;background:#2a2a2a;color:#fff;cursor:pointer;transition:all 0.2s;">🇬🇧 English</button>
      <button onclick="sparsSelectLang('lv')" id="spars-btn-lv" style="flex:1;min-width:140px;padding:14px 24px;font-size:16px;font-weight:600;border:2px solid #555;border-radius:8px;background:#2a2a2a;color:#fff;cursor:pointer;transition:all 0.2s;">🇱🇻 Latviešu</button>
    </div>
  </div>
</div>
<style>
  #spars-lang-popup button:hover { border-color: #c8a951 !important; background: #333 !important; }
  #spars-lang-popup .spars-highlight { border-color: #c8a951 !important; box-shadow: 0 0 12px rgba(200,169,81,0.3); }
  @media (max-width: 480px) {
    #spars-lang-buttons { flex-direction: column !important; }
    #spars-lang-buttons button { min-width: 100% !important; }
  }
</style>
<script>
(function() {
  var path = window.location.pathname;
  // If already on /lv path, set preference silently
  if (path.indexOf('/lv') === 0 && (path.length === 3 || path[3] === '/')) {
    localStorage.setItem('spars_lang', 'lv');
    return;
  }
  // If language already chosen, don't show
  if (localStorage.getItem('spars_lang')) return;
  // Show popup
  var popup = document.getElementById('spars-lang-popup');
  popup.style.display = 'flex';
  // Pre-highlight LV if browser is Latvian
  if ((navigator.language || navigator.userLanguage || '').toLowerCase().indexOf('lv') === 0) {
    document.getElementById('spars-btn-lv').classList.add('spars-highlight');
  }
})();
function sparsSelectLang(lang) {
  localStorage.setItem('spars_lang', lang);
  var path = window.location.pathname;
  if (lang === 'lv') {
    if (path.indexOf('/lv') !== 0) {
      window.location.href = '/lv' + path;
    }
  } else {
    // Remove /lv prefix if present
    if (path.indexOf('/lv') === 0) {
      window.location.href = path.substring(3) || '/';
    } else {
      window.location.reload();
    }
  }
}
</script>
{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{{ 'section-footer.css' | asset_url | stylesheet_tag }}
{{ 'component-list-payment.css' | asset_url | stylesheet_tag }}
{{ 'component-list-social.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .footer {
    margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
  }

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .footer {
      margin-top: {{ section.settings.margin_top }}px;
    }

    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* Custom SPARS Footer Styles */
  .spars-footer {
    background-color: #000000;
    color: #e0e0e0;
    padding: 60px 0 0;
  }

  .spars-footer-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 40px;
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 2rem;
  }

  @media screen and (max-width: 989px) {
    .spars-footer-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 30px;
    }
  }

  @media screen and (max-width: 549px) {
    .spars-footer-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }
  }

  .spars-footer h3 {
    color: #ffffff;
    font-size: 1.6rem;
    font-weight: 700;
    margin-bottom: 20px;
    text-transform: uppercase;
    letter-spacing: 0.1rem;
  }

  .spars-footer p,
  .spars-footer li,
  .spars-footer a {
    font-size: 1.4rem;
    line-height: 1.8;
    color: #b0b0b0;
  }

  .spars-footer a {
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .spars-footer a:hover {
    color: #ffffff;
  }

  .spars-footer ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .spars-footer ul li {
    margin-bottom: 8px;
  }

  .spars-footer-contact-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    margin-bottom: 12px;
  }

  .spars-footer-contact-item svg {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    margin-top: 3px;
    fill: #b0b0b0;
  }

  .spars-footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.1);
    margin-top: 40px;
    padding: 24px 2rem;
  }

  .spars-footer-bottom-inner {
    max-width: var(--page-width);
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
  }

  .spars-footer-copyright {
    font-size: 1.3rem;
    color: #888;
  }

  .spars-footer-trust {
    font-size: 1.3rem;
    color: #888;
    font-style: italic;
  }

  .spars-footer-vat {
    font-size: 1.2rem;
    color: #999;
    background: rgba(255,255,255,0.05);
    padding: 4px 12px;
    border-radius: 4px;
  }

  .spars-footer-payments {
    margin-top: 20px;
    padding-top: 16px;
    max-width: var(--page-width);
    margin-left: auto;
    margin-right: auto;
    padding-left: 2rem;
    padding-right: 2rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  .spars-footer-payments .icon {
    width: 38px;
    height: 24px;
  }

  .spars-footer-social {
    display: flex;
    gap: 12px;
    margin-top: 16px;
  }

  .spars-footer-social a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(255,255,255,0.1);
    transition: background 0.2s ease;
  }

  .spars-footer-social a:hover {
    background: rgba(255,255,255,0.2);
  }

  .spars-footer-social svg {
    width: 18px;
    height: 18px;
    fill: #b0b0b0;
  }

  @media screen and (max-width: 549px) {
    .spars-footer-bottom-inner {
      flex-direction: column;
      text-align: center;
    }
  }
{%- endstyle -%}

<footer class="spars-footer section-{{ section.id }}-padding">
  <div class="spars-footer-grid">
    <!-- Column 1: Company Info -->
    <div class="spars-footer-col">
      <h3>SPARS</h3>
      <p><strong>PATRIUS SIA</strong></p>
      <p>Buru iela 13A<br>Rīga 1004, Latvia</p>
      <div class="spars-footer-social">
        {%- if settings.social_facebook_link != blank -%}
          <a href="{{ settings.social_facebook_link }}" target="_blank" rel="noopener" aria-label="Facebook">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
          </a>
        {%- endif -%}
      </div>
    </div>

    <!-- Column 2: Quick Links -->
    <div class="spars-footer-col">
      <h3>{%- if request.locale.iso_code == 'lv' -%}Ātrās saites{%- else -%}Quick Links{%- endif -%}</h3>
      <ul>
        <li><a href="/collections/all">{%- if request.locale.iso_code == 'lv' -%}Veikals{%- else -%}Shop{%- endif -%}</a></li>
        <li><a href="/pages/about-us">{%- if request.locale.iso_code == 'lv' -%}Par mums{%- else -%}About Us{%- endif -%}</a></li>
        <li><a href="/pages/contact">{%- if request.locale.iso_code == 'lv' -%}Kontakti{%- else -%}Contact{%- endif -%}</a></li>
        <li><a href="/pages/customization">{%- if request.locale.iso_code == 'lv' -%}Pielāgošana{%- else -%}Customization{%- endif -%}</a></li>
        <li><a href="/pages/industries">{%- if request.locale.iso_code == 'lv' -%}Nozares{%- else -%}Industries{%- endif -%}</a></li>
      </ul>
    </div>

    <!-- Column 3: Legal -->
    <div class="spars-footer-col">
      <h3>{%- if request.locale.iso_code == 'lv' -%}Juridiskā informācija{%- else -%}Legal{%- endif -%}</h3>
      <ul>
        <li><a href="/pages/privacy-policy">{%- if request.locale.iso_code == 'lv' -%}Privātuma politika{%- else -%}Privacy Policy{%- endif -%}</a></li>
        <li><a href="/pages/terms-of-service">{%- if request.locale.iso_code == 'lv' -%}Pakalpojumu noteikumi{%- else -%}Terms of Service{%- endif -%}</a></li>
        <li><a href="/pages/cookie-policy">{%- if request.locale.iso_code == 'lv' -%}Sīkdatņu politika{%- else -%}Cookie Policy{%- endif -%}</a></li>
        <li><a href="/pages/shipping-policy">{%- if request.locale.iso_code == 'lv' -%}Piegādes politika{%- else -%}Shipping Policy{%- endif -%}</a></li>
        <li><a href="/pages/returns-refunds">{%- if request.locale.iso_code == 'lv' -%}Atgriešanas politika{%- else -%}Returns Policy{%- endif -%}</a></li>
      </ul>
    </div>

    <!-- Column 4: Contact -->
    <div class="spars-footer-col">
      <h3>{%- if request.locale.iso_code == 'lv' -%}Sazinies ar mums{%- else -%}Contact Us{%- endif -%}</h3>
      <div class="spars-footer-contact-item">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
        <a href="tel:+37128201587">+371 28201587</a>
      </div>
      <div class="spars-footer-contact-item">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6" fill="none" stroke="#b0b0b0" stroke-width="2"/></svg>
        <a href="mailto:f.strazdins@gmail.com">f.strazdins@gmail.com</a>
      </div>
      <div class="spars-footer-contact-item">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3" fill="none" stroke="#b0b0b0" stroke-width="2"/></svg>
        <span>Buru iela 13A, Rīga 1004</span>
      </div>
      <p style="margin-top: 16px; font-size: 1.3rem;">{%- if request.locale.iso_code == 'lv' -%}P.–Pk.: 9:00–17:00 (EET){%- else -%}Mon–Fri: 9:00–17:00 (EET){%- endif -%}</p>
    </div>
  </div>

  <!-- Payment Icons -->
  {%- if section.settings.payment_enable -%}
    <div class="spars-footer-payments">
      {%- for type in shop.enabled_payment_types -%}
        {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
      {%- endfor -%}
    </div>
  {%- endif -%}

  <!-- Bottom Bar -->
  <div class="spars-footer-bottom">
    <div class="spars-footer-bottom-inner">
      <span class="spars-footer-copyright">&copy; 2026 SPARS. {%- if request.locale.iso_code == 'lv' -%}Visas tiesības aizsargātas{%- else -%}All rights reserved{%- endif -%}.</span>
      <span class="spars-footer-vat">{%- if request.locale.iso_code == 'lv' -%}Visas cenas iekļauj PVN{%- else -%}All prices include VAT{%- endif -%}</span>
      <span class="spars-footer-trust">{%- if request.locale.iso_code == 'lv' -%}Profesionāls darba apģērbs atbilstoši ES drošības standartiem{%- else -%}Professional workwear meeting EU safety standards{%- endif -%}</span>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "t:sections.footer.name",
  "blocks": [],
  "settings": [
    {
      "type": "checkbox",
      "id": "payment_enable",
      "default": true,
      "label": "Show payment icons"
    },
    {
      "type": "header",
      "content": "t:sections.all.spacing"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.footer.settings.margin_top.label",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ]
}
{% endschema %}

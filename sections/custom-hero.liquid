{{ 'custom-hero.css' | asset_url | stylesheet_tag }}

<section class="custom-hero" id="hero-{{ section.id }}">
  {%- if section.settings.image -%}
    <div class="custom-hero__media">
      {%- assign img = section.settings.image -%}
      <img
        srcset="{{ img | image_url: width: 750 }} 750w,
               {{ img | image_url: width: 1100 }} 1100w,
               {{ img | image_url: width: 1500 }} 1500w,
               {{ img | image_url: width: 1920 }} 1920w,
               {{ img | image_url: width: 2560 }} 2560w"
        sizes="100vw"
        src="{{ img | image_url: width: 1920 }}"
        alt="{{ img.alt | default: section.settings.heading }}"
        loading="eager"
        fetchpriority="high"
        width="{{ img.width }}"
        height="{{ img.height }}"
      >
    </div>
  {%- endif -%}

  <div class="custom-hero__cta-wrap">
    <a href="{{ section.settings.button_link | default: '/pages/shop' }}" class="custom-hero__cta">
      {%- if request.locale.iso_code == 'lv' -%}
        Iepirkties
      {%- else -%}
        {{ section.settings.button_label | default: 'Shop Now' }}
      {%- endif -%}
    </a>
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading (SEO only)",
      "default": "Workwear and Sportswear"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "checkbox",
      "id": "hide_overlay",
      "label": "Hide text overlay",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}

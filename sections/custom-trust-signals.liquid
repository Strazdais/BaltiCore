{%- style -%}
  .trust-signals {
    background: #1a1a2e;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  @media screen and (max-width: 749px) {
    .trust-signals {
      padding-top: {{ section.settings.padding_top | times: 0.6 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.6 | round: 0 }}px;
    }
  }
  .trust-signals__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
    text-align: center;
  }
  .trust-signals__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }
  .trust-signals__icon {
    width: 44px;
    height: 44px;
    color: #b77831;
  }
  .trust-signals__icon svg {
    width: 100%;
    height: 100%;
  }
  .trust-signals__title {
    font-family: var(--font-heading-family, sans-serif);
    font-size: 15px;
    font-weight: 600;
    color: #ffffff;
    margin: 0;
    line-height: 1.3;
  }
  .trust-signals__sub {
    font-size: 13px;
    color: rgba(255,255,255,0.6);
    margin: 0;
    line-height: 1.4;
  }
  @media screen and (max-width: 989px) {
    .trust-signals__inner {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }
  }
  @media screen and (max-width: 749px) {
    .trust-signals__inner {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }
    .trust-signals__icon {
      width: 36px;
      height: 36px;
    }
    .trust-signals__title {
      font-size: 14px;
    }
  }
{%- endstyle -%}

<section class="trust-signals" id="TrustSignals-{{ section.id }}">
  <div class="trust-signals__inner">
    <div class="trust-signals__item">
      <div class="trust-signals__icon">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
      </div>
      <p class="trust-signals__title">{% if request.locale.iso_code == 'lv' %}EN ISO / CE sertificēts{% else %}EN ISO / CE Certified{% endif %}</p>
      <p class="trust-signals__sub">{% if request.locale.iso_code == 'lv' %}Produkti atbilstoši ES drošības standartiem{% else %}Products meeting EU safety standards{% endif %}</p>
    </div>
    <div class="trust-signals__item">
      <div class="trust-signals__icon">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
      </div>
      <p class="trust-signals__title">{% if request.locale.iso_code == 'lv' %}Bezmaksas piegāde Latvijā{% else %}Free Shipping in Latvia{% endif %}</p>
      <p class="trust-signals__sub">{% if request.locale.iso_code == 'lv' %}Visiem pasūtījumiem{% else %}On all orders{% endif %}</p>
    </div>
    <div class="trust-signals__item">
      <div class="trust-signals__icon">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
      </div>
      <p class="trust-signals__title">{% if request.locale.iso_code == 'lv' %}Droša apmaksa{% else %}Secure Checkout{% endif %}</p>
      <p class="trust-signals__sub">{% if request.locale.iso_code == 'lv' %}SSL šifrēti maksājumi{% else %}SSL encrypted payments{% endif %}</p>
    </div>
    <div class="trust-signals__item">
      <div class="trust-signals__icon">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
      </div>
      <p class="trust-signals__title">{% if request.locale.iso_code == 'lv' %}ES bāzēts piegādātājs{% else %}EU-Based Supplier{% endif %}</p>
      <p class="trust-signals__sub">{% if request.locale.iso_code == 'lv' %}PATRIUS SIA, Rīga, Latvija{% else %}PATRIUS SIA, Riga, Latvia{% endif %}</p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Trust Signals",
  "tag": "section",
  "class": "trust-signals-wrapper",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Trust Signals"
    }
  ]
}
{% endschema %}

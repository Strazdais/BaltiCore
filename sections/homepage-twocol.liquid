<section class="hp-twocol" style="background:{{ section.settings.bg_color | default: '#1a1a1a' }};">

  <div class="hp-twocol__grid">
    <!-- LEFT: Collections Carousel -->
    <div class="hp-twocol__left">

      <div class="hp-carousel" data-carousel>
        <div class="hp-carousel__track" data-track>
          {%- for block in section.blocks -%}
            {%- if block.type == 'collection_slide' -%}
              {%- assign col = block.settings.collection -%}
              {%- if col != blank -%}
                {%- assign col_obj = collections[col] -%}
                {%- if col_obj -%}
                  <div class="hp-carousel__slide" data-slide="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
                    <div class="hp-carousel__img-wrap">
                      {%- if col_obj.image -%}
                        <img src="{{ col_obj.image | image_url: width: 800 }}" alt="{{ col_obj.title }}" loading="lazy">
                      {%- elsif col_obj.products.first.featured_image -%}
                        <img src="{{ col_obj.products.first.featured_image | image_url: width: 800 }}" alt="{{ col_obj.title }}" loading="lazy">
                      {%- else -%}
                        <div class="hp-carousel__placeholder"></div>
                      {%- endif -%}
                    </div>
                    <div class="hp-carousel__overlay">
                      <span class="hp-carousel__label">
                        {%- if request.locale.iso_code == 'lv' -%}Kolekcijas{%- else -%}Collections{%- endif -%}
                      </span>
                      <h3 class="hp-carousel__title">{{ col_obj.title }}</h3>
                      <a href="{{ col_obj.url }}" class="hp-carousel__btn">
                        {%- if request.locale.iso_code == 'lv' -%}Skatīt Kolekciju{%- else -%}Shop Collection{%- endif -%}
                      </a>
                    </div>
                  </div>
                {%- endif -%}
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}
        </div>

        <!-- Navigation arrows -->
        <button class="hp-carousel__arrow hp-carousel__arrow--prev" data-prev aria-label="Previous">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#c8a951" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <button class="hp-carousel__arrow hp-carousel__arrow--next" data-next aria-label="Next">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#c8a951" stroke-width="2"><polyline points="9 6 15 12 9 18"/></svg>
        </button>

        <!-- Dots (inside carousel, absolute positioned) -->
        <div class="hp-carousel__dots" data-dots></div>
      </div>
    </div>

    <!-- RIGHT: Custom Print & Embroidery -->
    <div class="hp-twocol__right">
      {%- if section.settings.right_bg_image -%}
        <div class="hp-twocol__right-bg">
          <img src="{{ section.settings.right_bg_image | image_url: width: 900 }}" alt="" loading="lazy">
        </div>
      {%- endif -%}

      <div class="hp-twocol__right-content">
        <span class="hp-twocol__label hp-twocol__label--gold">
          {%- if request.locale.iso_code == 'lv' -%}Individuāla Apdruka un Izšūšana{%- else -%}Custom Print &amp; Embroidery{%- endif -%}
        </span>

        <h2 class="hp-twocol__heading">
          {%- if request.locale.iso_code == 'lv' -%}Personalizē savu ekipējumu.{%- else -%}Personalise your gear.{%- endif -%}
        </h2>

        <p class="hp-twocol__body">
          {%- if request.locale.iso_code == 'lv' -%}
            Izveido savu unikālo identitāti ar profesionālu zīmolvedību. Mēs piedāvājam augstākās kvalitātes izšūšanas un izturīgas apdruka risinājumus visiem darba apģērbiem.
          {%- else -%}
            Create your unique identity with professional branding. We offer premium embroidery and durable print solutions for all workwear.
          {%- endif -%}
        </p>

        <div class="hp-twocol__features">
          <div class="hp-twocol__feature">
            <span class="hp-twocol__feature-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#c8a951" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2L12 22"/>
                <path d="M5 9c0-3 3-5 7-5s7 2 7 5"/>
                <path d="M5 15c0 3 3 5 7 5s7-2 7-5"/>
                <path d="M3 12h4M17 12h4"/>
              </svg>
            </span>
            <span class="hp-twocol__feature-label">
              {%- if request.locale.iso_code == 'lv' -%}Izšūšana{%- else -%}Embroidery{%- endif -%}
            </span>
          </div>
          <div class="hp-twocol__feature">
            <span class="hp-twocol__feature-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#c8a951" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="6" y="3" width="12" height="18" rx="1"/>
                <line x1="6" y1="7" x2="18" y2="7"/>
                <line x1="6" y1="15" x2="18" y2="15"/>
                <line x1="10" y1="15" x2="10" y2="21"/>
              </svg>
            </span>
            <span class="hp-twocol__feature-label">
              {%- if request.locale.iso_code == 'lv' -%}Apdruka{%- else -%}Print{%- endif -%}
            </span>
          </div>
        </div>

        <a href="/pages/customization" class="hp-twocol__cta">
          {%- if request.locale.iso_code == 'lv' -%}Pieprasīt Pielāgošanu{%- else -%}Request Customisation{%- endif -%}
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .hp-twocol {
    margin-top: 12px;
  }

  .hp-twocol__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    max-width: 100%;
    margin: 0;
    padding: 0 0;
  }

  /* ===== LEFT: CAROUSEL ===== */
  .hp-twocol__left {
    position: relative;
  }

  .hp-carousel {
    position: relative;
    overflow: hidden;
    height: 100%;
  }

  .hp-carousel__track {
    display: flex;
    transition: transform 0.5s ease;
    will-change: transform;
    height: 100%;
  }

  .hp-carousel__slide {
    min-width: 100%;
    position: relative;
    flex-shrink: 0;
    height: 320px;
  }

  .hp-carousel__img-wrap {
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .hp-carousel__img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hp-carousel__placeholder {
    width: 100%;
    height: 100%;
    background: #2a2a2a;
  }

  .hp-carousel__overlay {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 20px 24px;
    background: linear-gradient(170deg, rgba(0,0,0,0.35) 0%, transparent 40%, transparent 50%, rgba(0,0,0,0.7) 100%);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .hp-carousel__label {
    display: block;
    font-size: 1.1rem;
    font-weight: 700;
    color: #fff;
    letter-spacing: 0.02em;
  }

  .hp-carousel__bottom {
    display: flex;
    flex-direction: column;
  }

  .hp-carousel__title {
    color: #fff;
    font-size: 1.2rem;
    font-weight: 700;
    margin: 0 0 10px;
    letter-spacing: 0.02em;
  }

  .hp-carousel__btn {
    display: inline-block;
    width: fit-content;
    background: transparent;
    color: #fff;
    font-weight: 600;
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 8px 20px;
    border-radius: 4px;
    border: 1px solid rgba(255,255,255,0.5);
    transition: all 0.25s ease;
  }

  .hp-carousel__btn:hover {
    background: #c8a951;
    color: #1a1a1a;
    border-color: #c8a951;
  }

  /* Arrows */
  .hp-carousel__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(0, 0, 0, 0.4);
    border: none;
    border-radius: 50%;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 5;
    transition: background 0.2s;
    opacity: 0;
  }

  .hp-carousel:hover .hp-carousel__arrow {
    opacity: 1;
  }

  .hp-carousel__arrow:hover {
    background: rgba(0, 0, 0, 0.7);
  }

  .hp-carousel__arrow--prev { left: 10px; }
  .hp-carousel__arrow--next { right: 10px; }

  /* Dots */
  .hp-carousel__dots {
    position: absolute;
    bottom: 12px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 6px;
    z-index: 5;
  }

  .hp-carousel__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255,255,255,0.35);
    border: none;
    cursor: pointer;
    transition: background 0.3s;
    padding: 0;
  }

  .hp-carousel__dot.active {
    background: #fff;
  }

  /* ===== RIGHT: CUSTOMISATION ===== */
  .hp-twocol__right {
    position: relative;
    overflow: hidden;
    display: flex;
    padding: 24px 32px;
    height: 320px;
    box-sizing: border-box;
  }

  .hp-twocol__right-bg {
    position: absolute;
    top: 0;
    right: 0;
    width: 45%;
    height: 100%;
    z-index: 0;
  }

  .hp-twocol__right-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.5;
    mask-image: linear-gradient(to right, transparent 0%, black 50%);
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 50%);
  }

  .hp-twocol__right-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    max-width: 380px;
  }

  .hp-twocol__label {
    display: block;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #c8a951;
    margin-bottom: 8px;
    font-style: italic;
  }

  .hp-twocol__heading {
    color: #fff;
    font-size: 1.5rem;
    font-weight: 700;
    line-height: 1.2;
    margin: 0 0 10px;
  }

  .hp-twocol__body {
    color: rgba(255,255,255,0.65);
    font-size: 0.82rem;
    line-height: 1.6;
    margin: 0 0 18px;
  }

  .hp-twocol__features {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 20px;
  }

  .hp-twocol__feature {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .hp-twocol__feature-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border: 1px solid rgba(200, 169, 81, 0.25);
    border-radius: 8px;
    flex-shrink: 0;
  }

  .hp-twocol__feature-icon svg {
    width: 22px;
    height: 22px;
  }

  .hp-twocol__feature-label {
    color: #fff;
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .hp-twocol__cta {
    display: block;
    width: 100%;
    text-align: center;
    background: #c8a951;
    color: #1a1a1a;
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 13px 24px;
    border-radius: 4px;
    transition: background 0.25s ease;
    box-sizing: border-box;
  }

  .hp-twocol__cta:hover {
    background: #d4b85e;
  }

  /* ===== MOBILE ===== */
  @media (max-width: 767px) {
    .hp-twocol__grid {
      grid-template-columns: 1fr;
      gap: 8px;
    }

    .hp-carousel__slide {
      height: 240px;
    }

    .hp-twocol__right {
      height: auto;
      padding: 28px 20px;
    }

    .hp-twocol__heading {
      font-size: 1.3rem;
    }

    .hp-twocol__right-bg {
      width: 100%;
      opacity: 0.15;
    }

    .hp-carousel__title {
      font-size: 1rem;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('[data-carousel]').forEach(function (carousel) {
      var track = carousel.querySelector('[data-track]');
      var slides = carousel.querySelectorAll('[data-slide]');
      var dotsWrap = carousel.querySelector('[data-dots]');
      var prevBtn = carousel.querySelector('[data-prev]');
      var nextBtn = carousel.querySelector('[data-next]');
      var current = 0;
      var total = slides.length;
      var autoInterval = null;
      var paused = false;

      if (total < 1) return;

      // Build dots
      for (var i = 0; i < total; i++) {
        var dot = document.createElement('button');
        dot.className = 'hp-carousel__dot' + (i === 0 ? ' active' : '');
        dot.setAttribute('data-index', i);
        dot.setAttribute('aria-label', 'Slide ' + (i + 1));
        dotsWrap.appendChild(dot);
      }

      function goTo(idx) {
        if (idx < 0) idx = total - 1;
        if (idx >= total) idx = 0;
        current = idx;
        track.style.transform = 'translateX(-' + (current * 100) + '%)';
        var dots = dotsWrap.querySelectorAll('.hp-carousel__dot');
        dots.forEach(function (d, j) {
          d.classList.toggle('active', j === current);
        });
      }

      function startAuto() {
        stopAuto();
        autoInterval = setInterval(function () {
          if (!paused) goTo(current + 1);
        }, 4000);
      }

      function stopAuto() {
        if (autoInterval) clearInterval(autoInterval);
      }

      prevBtn.addEventListener('click', function () { goTo(current - 1); startAuto(); });
      nextBtn.addEventListener('click', function () { goTo(current + 1); startAuto(); });

      dotsWrap.addEventListener('click', function (e) {
        var idx = e.target.getAttribute('data-index');
        if (idx !== null) { goTo(parseInt(idx)); startAuto(); }
      });

      carousel.addEventListener('mouseenter', function () { paused = true; });
      carousel.addEventListener('mouseleave', function () { paused = false; });

      // Touch swipe
      var touchStartX = 0;
      var touchEndX = 0;
      carousel.addEventListener('touchstart', function (e) {
        touchStartX = e.changedTouches[0].screenX;
      }, { passive: true });
      carousel.addEventListener('touchend', function (e) {
        touchEndX = e.changedTouches[0].screenX;
        var diff = touchStartX - touchEndX;
        if (Math.abs(diff) > 40) {
          goTo(diff > 0 ? current + 1 : current - 1);
          startAuto();
        }
      }, { passive: true });

      startAuto();
    });
  });
</script>

{% schema %}
{
  "name": "Homepage Two Column",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#1a1a1a"
    },
    {
      "type": "image_picker",
      "id": "right_bg_image",
      "label": "Right column background image"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 48,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "collection_slide",
      "name": "Collection Slide",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Homepage Two Column",
      "blocks": []
    }
  ]
}
{% endschema %}

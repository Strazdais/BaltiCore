{% comment %}
  Homepage Two-Column Section: Customization pitch + Recommended products carousel

  HOW TO UPDATE RECOMMENDED PRODUCTS:
  Go to Shopify Admin → Products → Collections → "Homepage Recommended"
  Add or remove products from that collection. They appear here automatically.
  Products display in the manual sort order set in the collection.
{% endcomment %}

{%- style -%}
  .homepage-twocol {
    background: {{ section.settings.bg_color }} !important; color: #fff;
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }
  .homepage-twocol__inner {
    max-width: var(--page-width, 1200px);
    margin: 0 auto;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: start;
  }
  .homepage-twocol__heading {
    font-family: var(--font-heading-family, sans-serif);
    font-size: 2.8rem;
    font-weight: 700;
    font-style: italic;
    color: #c8a951;
    margin: 0 0 20px;
    line-height: 1.2;
  }
  .homepage-twocol__body {
    font-size: 1.5rem;
    line-height: 1.7;
    color: rgba(255,255,255,0.75);
    margin: 0 0 36px;
  }
  .homepage-twocol__features {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
    margin-bottom: 36px;
  }
  .homepage-twocol__feature-icon {
    width: 48px;
    height: 48px;
    color: #c8a951;
    margin-bottom: 12px;
  }
  .homepage-twocol__feature-icon svg {
    width: 100%;
    height: 100%;
  }
  .homepage-twocol__feature-label {
    font-family: var(--font-heading-family, sans-serif);
    font-size: 1.8rem;
    font-weight: 700;
    color: #ffffff;
    margin: 0 0 8px;
  }
  .homepage-twocol__feature-text {
    font-size: 1.4rem;
    line-height: 1.6;
    color: rgba(255,255,255,0.6);
    margin: 0;
  }
  .homepage-twocol__cta {
    display: inline-block;
    background: #c8a951;
    color: #1a1a1a;
    font-family: var(--font-heading-family, sans-serif);
    font-size: 1.5rem;
    font-weight: 600;
    padding: 14px 32px;
    border-radius: 6px;
    text-decoration: none;
    transition: background 0.2s, transform 0.2s;
    letter-spacing: 0.02em;
  }
  .homepage-twocol__cta:hover {
    background: #d4b85c;
    transform: translateY(-1px);
  }

  /* Right column - products */
  .homepage-twocol__products-heading {
    font-family: var(--font-heading-family, sans-serif);
    font-size: 2.8rem;
    font-weight: 700;
    color: #ffffff;
    margin: 0 0 24px;
    line-height: 1.2;
  }
  .homepage-twocol__carousel {
    position: relative;
    overflow: hidden;
  }
  .homepage-twocol__track {
    display: flex;
    transition: transform 0.4s ease;
    gap: 16px;
  }
  .homepage-twocol__card {
    flex: 0 0 calc(33.333% - 11px);
    min-width: 0;
    background: #2a2a2a;
    border-radius: 8px;
    overflow: hidden;
    text-decoration: none;
    display: block;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .homepage-twocol__card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.3);
  }
  .homepage-twocol__card-img {
    width: 100%;
    aspect-ratio: 1/1;
    object-fit: contain;
    background: #f5f5f5;
    display: block;
  }
  .homepage-twocol__card-info {
    padding: 12px 14px 16px;
  }
  .homepage-twocol__card-title {
    font-size: 1.3rem;
    font-weight: 500;
    color: #ffffff;
    margin: 0 0 6px;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .homepage-twocol__card-price {
    font-size: 1.5rem;
    font-weight: 700;
    color: #c8a951;
    margin: 0;
  }

  /* Carousel arrows */
  .homepage-twocol__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-80%);
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(200,169,81,0.9);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #1a1a1a;
    z-index: 2;
    transition: background 0.2s;
    padding: 0;
  }
  .homepage-twocol__arrow:hover {
    background: #d4b85c;
  }
  .homepage-twocol__arrow--prev { left: -4px; }
  .homepage-twocol__arrow--next { right: -4px; }
  .homepage-twocol__arrow svg {
    width: 18px;
    height: 18px;
  }

  /* Dots */
  .homepage-twocol__dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 16px;
  }
  .homepage-twocol__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255,255,255,0.3);
    border: none;
    padding: 0;
    cursor: pointer;
    transition: background 0.2s;
  }
  .homepage-twocol__dot.active {
    background: #c8a951;
  }

  /* Mobile */
  @media screen and (max-width: 989px) {
    .homepage-twocol__inner {
      grid-template-columns: 1fr;
      gap: 48px;
    }
    .homepage-twocol__heading,
    .homepage-twocol__products-heading {
      font-size: 2.4rem;
    }
  }
  @media screen and (max-width: 749px) {
    .homepage-twocol {
      padding: {{ section.settings.padding_top | times: 0.6 | round: 0 }}px 0 {{ section.settings.padding_bottom | times: 0.6 | round: 0 }}px;
    }
    .homepage-twocol__features {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .homepage-twocol__card {
      flex: 0 0 calc(100% - 0px);
    }
    .homepage-twocol__heading,
    .homepage-twocol__products-heading {
      font-size: 2rem;
    }
  }
{%- endstyle -%}

<section class="homepage-twocol" id="HomepageTwocol-{{ section.id }}">
  <div class="homepage-twocol__inner">
    {%- comment -%} LEFT COLUMN — Customization pitch {%- endcomment -%}
    <div class="homepage-twocol__left">
      <h2 class="homepage-twocol__heading">
        {%- if request.locale.iso_code == 'lv' -%}Personalizēts Jums{%- else -%}Personalised for You{%- endif -%}
      </h2>
      <p class="homepage-twocol__body">
        {%- if request.locale.iso_code == 'lv' -%}
          Jūsu logo, jūsu krāsas, jūsu zīmols — uz katra apģērba. Mēs piedāvājam profesionālus izšūšanas un apdruku risinājumus darba apģērbam visās nozarēs. Neatkarīgi no tā, vai tas ir krūšu logo vai pilns individuāls dizains, mēs parūpēsimies, lai jūsu komanda izskatās profesionāli.
        {%- else -%}
          Your logo, your colours, your brand — on every garment. We offer professional embroidery and print solutions for workwear across all industries. Whether it's a chest logo or a full custom design, we make sure your team looks the part.
        {%- endif -%}
      </p>

      <div class="homepage-twocol__features">
        <div class="homepage-twocol__feature">
          <div class="homepage-twocol__feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2L2 7l10 5 10-5-10-5z"/>
              <path d="M2 17l10 5 10-5"/>
              <path d="M2 12l10 5 10-5"/>
              <line x1="12" y1="22" x2="12" y2="17"/>
              <path d="M20 7v.5c0 .6-.4 1.1-.9 1.4L12 12"/>
            </svg>
          </div>
          <h3 class="homepage-twocol__feature-label">
            {%- if request.locale.iso_code == 'lv' -%}Izšūšana{%- else -%}Embroidery{%- endif -%}
          </h3>
          <p class="homepage-twocol__feature-text">
            {%- if request.locale.iso_code == 'lv' -%}
              Veidojiet savu unikālo identitāti ar precīzi izšūtiem logo un brendingu uz jūsu darba apģērba.
            {%- else -%}
              Create your unique identity with precision embroidered logos and branding on your workwear.
            {%- endif -%}
          </p>
        </div>
        <div class="homepage-twocol__feature">
          <div class="homepage-twocol__feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="6" y="3" width="12" height="18" rx="1"/>
              <path d="M6 8h12"/>
              <path d="M6 16h12"/>
              <path d="M10 3v5"/>
              <path d="M14 3v5"/>
              <path d="M10 16v5"/>
              <path d="M14 16v5"/>
            </svg>
          </div>
          <h3 class="homepage-twocol__feature-label">
            {%- if request.locale.iso_code == 'lv' -%}Apdruka{%- else -%}Print{%- endif -%}
          </h3>
          <p class="homepage-twocol__feature-text">
            {%- if request.locale.iso_code == 'lv' -%}
              Augstas kvalitātes apdruka jūsu unikālai zīmola identitātei uz jebkura apģērba.
            {%- else -%}
              High-quality print application for your unique brand identity on any garment.
            {%- endif -%}
          </p>
        </div>
      </div>

      <a href="/pages/customization" class="homepage-twocol__cta">
        {%- if request.locale.iso_code == 'lv' -%}Apskatīt pielāgošanu →{%- else -%}Explore customisation →{%- endif -%}
      </a>
    </div>

    {%- comment -%} RIGHT COLUMN — Recommended products carousel {%- endcomment -%}
    <div class="homepage-twocol__right">
      <h2 class="homepage-twocol__products-heading">
        {%- if request.locale.iso_code == 'lv' -%}Ieteiktie produkti{%- else -%}Recommended Products{%- endif -%}
      </h2>

      {%- assign rec_collection = collections['homepage-recommended'] -%}
      {%- if rec_collection and rec_collection.products.size > 0 -%}
        <div class="homepage-twocol__carousel" id="twocol-carousel-{{ section.id }}">
          <div class="homepage-twocol__track" id="twocol-track-{{ section.id }}">
            {%- for product in rec_collection.products limit: 12 -%}
              <a href="{{ product.url }}" class="homepage-twocol__card">
                {%- if product.featured_image -%}
                  <img
                    src="{{ product.featured_image | image_url: width: 400 }}"
                    alt="{{ product.featured_image.alt | default: product.title | escape }}"
                    class="homepage-twocol__card-img"
                    width="400"
                    height="400"
                    loading="lazy"
                  >
                {%- else -%}
                  <div class="homepage-twocol__card-img" style="background:#ddd;display:flex;align-items:center;justify-content:center;color:#999;font-size:1.2rem;">No image</div>
                {%- endif -%}
                <div class="homepage-twocol__card-info">
                  <p class="homepage-twocol__card-title">{{ product.title }}</p>
                  <p class="homepage-twocol__card-price">{{ product.price | money }}</p>
                </div>
              </a>
            {%- endfor -%}
          </div>

          <button class="homepage-twocol__arrow homepage-twocol__arrow--prev" aria-label="Previous" id="twocol-prev-{{ section.id }}">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
          </button>
          <button class="homepage-twocol__arrow homepage-twocol__arrow--next" aria-label="Next" id="twocol-next-{{ section.id }}">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 6 15 12 9 18"/></svg>
          </button>

          <div class="homepage-twocol__dots" id="twocol-dots-{{ section.id }}"></div>
        </div>

        <script>
          (function() {
            var sectionId = '{{ section.id }}';
            var track = document.getElementById('twocol-track-' + sectionId);
            var prev = document.getElementById('twocol-prev-' + sectionId);
            var next = document.getElementById('twocol-next-' + sectionId);
            var dotsContainer = document.getElementById('twocol-dots-' + sectionId);
            if (!track) return;

            var cards = track.querySelectorAll('.homepage-twocol__card');
            var total = cards.length;
            var current = 0;
            var perView = window.innerWidth <= 749 ? 1 : 3;
            var maxIndex = Math.max(0, total - perView);
            var autoTimer;

            function getPerView() {
              return window.innerWidth <= 749 ? 1 : 3;
            }

            function buildDots() {
              dotsContainer.innerHTML = '';
              var pages = maxIndex + 1;
              for (var i = 0; i < pages; i++) {
                var dot = document.createElement('button');
                dot.className = 'homepage-twocol__dot' + (i === current ? ' active' : '');
                dot.setAttribute('aria-label', 'Go to slide ' + (i + 1));
                dot.dataset.index = i;
                dot.addEventListener('click', function() {
                  goTo(parseInt(this.dataset.index));
                  resetAuto();
                });
                dotsContainer.appendChild(dot);
              }
            }

            function goTo(index) {
              current = Math.max(0, Math.min(index, maxIndex));
              var cardWidth = cards[0].offsetWidth + 16; // gap
              track.style.transform = 'translateX(-' + (current * cardWidth) + 'px)';
              var dots = dotsContainer.querySelectorAll('.homepage-twocol__dot');
              dots.forEach(function(d, i) { d.classList.toggle('active', i === current); });
            }

            function nextSlide() { goTo(current >= maxIndex ? 0 : current + 1); }
            function prevSlide() { goTo(current <= 0 ? maxIndex : current - 1); }

            function startAuto() { autoTimer = setInterval(nextSlide, 5000); }
            function resetAuto() { clearInterval(autoTimer); startAuto(); }

            prev.addEventListener('click', function() { prevSlide(); resetAuto(); });
            next.addEventListener('click', function() { nextSlide(); resetAuto(); });

            window.addEventListener('resize', function() {
              perView = getPerView();
              maxIndex = Math.max(0, total - perView);
              if (current > maxIndex) current = maxIndex;
              buildDots();
              goTo(current);
            });

            buildDots();
            startAuto();
          })();
        </script>
      {%- else -%}
        <p style="color:rgba(255,255,255,0.5);font-size:1.4rem;">
          No recommended products yet. Add products to the "Homepage Recommended" collection.
        </p>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Homepage Two-Column",
  "tag": "section",
  "class": "homepage-twocol-wrapper",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 20,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 20,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Homepage Two-Column"
    }
  ]
}
{% endschema %}
